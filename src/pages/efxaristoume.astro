---
import Base from '../layouts/Base.astro';
import Icon from '../components/Icon.astro';
import { company } from '../data/site.js';
---
<Base title="Ευχαριστούμε — SafeCleaning" noindex={true}>
  <section class="thankyou">
    <div class="wrap thankyou__inner">
      <div class="thankyou__card">
        <div class="thankyou__mark" aria-hidden="true">
          <Icon name="check" size={28} stroke={2.2} />
        </div>
        <span class="eyebrow">Το αίτημά σας καταχωρήθηκε</span>
        <h1>Ευχαριστούμε για την επικοινωνία</h1>
        <p class="thankyou__lead">
          Η ομάδα της SafeCleaning θα επικοινωνήσει μαζί σας το συντομότερο δυνατό
          για να κανονίσουμε δωρεάν αυτοψία και να σας ετοιμάσουμε προσφορά.
        </p>
        <div class="thankyou__steps" aria-label="Επόμενα βήματα">
          <div>
            <span>01</span>
            <p>Εξετάζουμε τα στοιχεία του αιτήματός σας.</p>
          </div>
          <div>
            <span>02</span>
            <p>Επικοινωνούμε μαζί σας για τα επόμενα βήματα.</p>
          </div>
        </div>
        <div class="thankyou__actions">
          <a href="/" class="btn btn--outline">Επιστροφή στην αρχική</a>
          <a href={`tel:${company.phoneMobileHref}`} class="btn btn--solid">
            <Icon name="phone" size={18} stroke={2} /> Κλήση τώρα
          </a>
        </div>
      </div>
    </div>
  </section>
</Base>
