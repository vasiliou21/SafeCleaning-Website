---
import Base from '../../layouts/Base.astro';
import Icon from '../../components/Icon.astro';
import CtaBand from '../../components/CtaBand.astro';
import { services } from '../../data/site.js';

const title = 'Υπηρεσίες Καθαρισμού στην Παλλήνη & Αττική | SafeCleaning';
const description =
  'Όλες οι υπηρεσίες καθαρισμού της SafeCleaning στην Παλλήνη & Αττική: πολυκατοικίες, επαγγελματικοί χώροι, κτίρια και αρχικοί καθαρισμοί, με οικολογικά προϊόντα.';
---
<Base title={title} description={description}>
  <section class="pagehero">
    <div class="wrap">
      <p class="crumbs"><a href="/">Αρχική</a> / Υπηρεσίες</p>
      <span class="eyebrow">Οι υπηρεσίες μας</span>
      <h1>Καθαρισμοί προσαρμοσμένοι σε κάθε χώρο</h1>
      <p>Τέσσερις εξειδικευμένες υπηρεσίες για πολυκατοικίες, επιχειρήσεις και κτίρια.
        Σε κάθε περίπτωση, η αυτοψία και η προσφορά γίνονται χωρίς καμία χρέωση.</p>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      <div class="rows">
        {services.map((s, i) => (
          <article class={`row ${i % 2 === 1 ? 'row--flip' : ''}`} data-reveal>
            <a class="row__media" href={`/ypiresies/${s.slug}`} aria-label={s.title}>
              <img src={s.image} alt={s.imageAlt} loading="lazy" width="900" height="675" />
            </a>
            <div class="row__body">
              <div class="row__num">{s.num}</div>
              <h2><a href={`/ypiresies/${s.slug}`}>{s.title}</a></h2>
              <p>{s.short}</p>
              <div class="service__tags" style="margin-bottom: 22px;">
                {s.tags.map((t) => <span>{t}</span>)}
              </div>
              <a class="row__link" href={`/ypiresies/${s.slug}`}>
                Δείτε την υπηρεσία <Icon name="arrow" size={18} stroke={2} />
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <CtaBand />
</Base>
